<Page
    x:Class="RotationTracker.WidgetPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:RotationTracker"
    xmlns:conv="using:RotationTracker.Converters"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    RequestedTheme="Dark"
    Background="Transparent">

    <Page.Resources>
        <conv:BooleanToVisibilityConverter x:Key="BoolVis"/>
        <conv:BooleanToVisibilityConverter x:Key="BoolVisInverse" Invert="True"/>
        <conv:BooleanToOpacityConverter x:Key="ActiveOpacity" TrueOpacity="1.0" FalseOpacity="0.52"/>

        <SolidColorBrush x:Key="PanelSurfaceBrush" Color="#F01F2025"/>
        <SolidColorBrush x:Key="PanelStrokeBrush" Color="#33FFFFFF"/>
        <SolidColorBrush x:Key="LabelForeground" Color="#F2FFFFFF"/>
        <SolidColorBrush x:Key="SubLabelForeground" Color="#B0FFFFFF"/>
        <SolidColorBrush x:Key="CaptionFill" Color="#1FFFFFFF"/>
        <AcrylicBrush x:Key="InactiveOverlayBrush"
                      BackgroundSource="Backdrop"
                      TintColor="#FF111318"
                      TintOpacity="0.78"
                      FallbackColor="#CC111318"/>
    </Page.Resources>

    <Grid x:Name="RootGrid"
          Background="Transparent"
          Padding="10">
        <Border x:Name="CardBorder"
                CornerRadius="20"
                Background="{StaticResource PanelSurfaceBrush}"
                BorderBrush="{StaticResource PanelStrokeBrush}"
                BorderThickness="1"
                Padding="14,12,14,14">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0"
                                Orientation="Horizontal"
                                Spacing="4"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Top">
                        <Button x:Name="SettingsButton"
                                Click="OnSettingsClick"
                                ToolTipService.ToolTip="Edit rotations"
                                Padding="6"
                                MinWidth="0"
                                Background="Transparent">
                            <FontIcon Glyph="&#xE713;" FontSize="12"/>
                        </Button>
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                HorizontalAlignment="Stretch"
                                Spacing="6"
                                Margin="0,0,12,10">
                        <TextBlock Text="{x:Bind RotationName, Mode=OneWay}"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   TextAlignment="Center"
                                   Foreground="{StaticResource LabelForeground}"/>
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    Spacing="8">
                            <Border CornerRadius="999"
                                    Padding="10,4"
                                    Background="{StaticResource CaptionFill}">
                                <TextBlock Text="{x:Bind ProgressSummary, Mode=OneWay}"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource SubLabelForeground}"/>
                            </Border>
                            <Border CornerRadius="999"
                                    Padding="10,4"
                                    Background="{StaticResource CaptionFill}">
                                <TextBlock Text="{x:Bind CurrentActionSummary, Mode=OneWay}"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource SubLabelForeground}"/>
                            </Border>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="2"
                                Orientation="Horizontal"
                                Spacing="4"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top">
                        <Button x:Name="ResetButton"
                                Click="OnResetClick"
                                ToolTipService.ToolTip="Reset to first step"
                                Padding="6"
                                MinWidth="0"
                                Background="Transparent">
                            <FontIcon Glyph="&#xE72C;" FontSize="12"/>
                        </Button>
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="1"
                      Opacity="{x:Bind ContentOpacity, Mode=OneWay}">
                    <ScrollViewer x:Name="StepsScroller"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Center"
                                  HorizontalScrollMode="Enabled"
                                  HorizontalScrollBarVisibility="Hidden"
                                  VerticalScrollMode="Disabled"
                                  VerticalScrollBarVisibility="Disabled"
                                  ZoomMode="Disabled"
                                  Visibility="{x:Bind IsEmpty, Mode=OneWay, Converter={StaticResource BoolVisInverse}}">
                        <ItemsControl x:Name="StepsItems"
                                      ItemsSource="{x:Bind Steps, Mode=OneWay}"
                                      Padding="8,4,8,4"
                                      HorizontalAlignment="Center">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal"
                                                Spacing="18"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="local:StepViewModel">
                                    <StackPanel Width="98"
                                                Spacing="6"
                                                HorizontalAlignment="Center"
                                                Opacity="{x:Bind IsCurrent, Mode=OneWay, Converter={StaticResource ActiveOpacity}}">
                                        <Grid Width="76" Height="76" HorizontalAlignment="Center">
                                            <Ellipse Width="76" Height="76"
                                                     Fill="{x:Bind BadgeFillBrush, Mode=OneWay}"
                                                     Stroke="{x:Bind BadgeStrokeBrush, Mode=OneWay}"
                                                     StrokeThickness="2.5"/>

                                            <Image Width="68"
                                                   Height="68"
                                                   Stretch="UniformToFill"
                                                   Source="{x:Bind IconUrl, Mode=OneWay}"
                                                   Visibility="{x:Bind HasIcon, Mode=OneWay, Converter={StaticResource BoolVis}}"/>

                                            <TextBlock Text="?"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       FontSize="28"
                                                       FontWeight="Bold"
                                                       Opacity="0.35"
                                                       Visibility="{x:Bind HasIcon, Mode=OneWay, Converter={StaticResource BoolVisInverse}}"/>

                                            <Border Width="24"
                                                    Height="24"
                                                    CornerRadius="12"
                                                    HorizontalAlignment="Left"
                                                    VerticalAlignment="Bottom"
                                                    Margin="-2,0,0,-2"
                                                    Background="#FF2A2A30"
                                                    BorderBrush="#66000000"
                                                    BorderThickness="1"
                                                    Visibility="{x:Bind HasAvatar, Mode=OneWay, Converter={StaticResource BoolVis}}">
                                                <Image Stretch="UniformToFill"
                                                       Source="{x:Bind OperatorAvatarUrl, Mode=OneWay}"/>
                                            </Border>

                                            <Border HorizontalAlignment="Right"
                                                    VerticalAlignment="Top"
                                                    Margin="0,-3,-3,0"
                                                    CornerRadius="9"
                                                    Padding="5,2,5,2"
                                                    Background="{x:Bind KeyTagBrush, Mode=OneWay}">
                                                <StackPanel Orientation="Horizontal" Spacing="2">
                                                    <TextBlock Text="{x:Bind KeyHint, Mode=OneWay}"
                                                               FontSize="11"
                                                               FontWeight="Bold"
                                                               Foreground="{x:Bind KeyTagForegroundBrush, Mode=OneWay}"/>
                                                    <FontIcon Glyph="&#xE916;"
                                                              FontSize="9"
                                                              Foreground="{x:Bind KeyTagForegroundBrush, Mode=OneWay}"
                                                              Visibility="{x:Bind IsLongPress, Mode=OneWay, Converter={StaticResource BoolVis}}"/>
                                                </StackPanel>
                                            </Border>
                                        </Grid>

                                        <TextBlock Text="{x:Bind LabelText, Mode=OneWay}"
                                                   Foreground="{StaticResource LabelForeground}"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   TextAlignment="Center"
                                                   TextWrapping="Wrap"
                                                   MaxLines="2"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <StackPanel x:Name="EmptyPanel"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Spacing="10"
                                Visibility="{x:Bind IsEmpty, Mode=OneWay, Converter={StaticResource BoolVis}}">
                        <TextBlock Text="No rotation configured."
                                   TextAlignment="Center"
                                   FontSize="13"
                                   Foreground="{StaticResource LabelForeground}"
                                   Opacity="0.86"/>
                        <TextBlock Text="Open settings to pick a team and build your first sequence."
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"
                                   Foreground="{StaticResource SubLabelForeground}"
                                   Opacity="0.72"/>
                        <Button Content="Edit rotations"
                                Click="OnSettingsClick"
                                HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="1"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"
                      Background="{StaticResource InactiveOverlayBrush}"
                      Visibility="{x:Bind ShowInactiveOverlay, Mode=OneWay, Converter={StaticResource BoolVis}}"
                      IsHitTestVisible="False">
                    <Border HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Background="#D91A1B1F"
                            BorderBrush="#33FFFFFF"
                            BorderThickness="1"
                            CornerRadius="16"
                            Padding="18,14">
                        <StackPanel Spacing="6">
                            <TextBlock Text="Rotation inactive"
                                       HorizontalAlignment="Center"
                                       TextAlignment="Center"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource LabelForeground}"/>
                            <TextBlock Text="Press F10 to start"
                                       HorizontalAlignment="Center"
                                       TextAlignment="Center"
                                       FontSize="12"
                                       Foreground="{StaticResource SubLabelForeground}"/>
                            <TextBlock Text="Press F10 again to reset to inactive"
                                       HorizontalAlignment="Center"
                                       TextAlignment="Center"
                                       FontSize="11"
                                       Foreground="{StaticResource SubLabelForeground}"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Page>
